# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Set NODE_ENV=production and CLIENT_URL to your real domain when deploying.
CLIENT_URL=http://localhost:5173

# ─── MongoDB ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/raims_db?retryWrites=true&w=majority

# ─── JWT Access Token (short-lived) ───────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_random_64_char_hex_string
JWT_EXPIRE=15m

# ─── JWT Refresh Token (long-lived) ───────────────────────
# Generate a DIFFERENT random string than JWT_SECRET
JWT_REFRESH_SECRET=replace_with_another_random_64_char_hex_string
JWT_REFRESH_EXPIRE=7d

# ─── Email / Resend ────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=notifications@yourdomain.com
FROM_NAME=RAIMS Notifications

# ─── File Upload (local disk, served at /uploads) ─────────
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
