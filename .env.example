# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── MongoDB (Atlas Free Tier or Local) ───────────────────
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://raims_user:PASSWORD@cluster0.xxxxx.mongodb.net/raims?retryWrites=true&w=majority
# For local MongoDB:
# MONGO_URI=mongodb://localhost:27017/raims
MONGO_URI=mongodb+srv://raims_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/raims?retryWrites=true&w=majority

# ─── JWT Access Token (short-lived) ───────────────────────
JWT_SECRET=your_super_secret_jwt_access_key_min_32_chars
JWT_EXPIRE=15m

# ─── JWT Refresh Token (long-lived) ───────────────────────
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_min_32_chars
JWT_REFRESH_EXPIRE=7d

# ─── Email / Resend (https://resend.com) ──────────────────
# Sign up free, get API key from dashboard
RESEND_API_KEY=re_your_api_key_here
# For testing: use onboarding@resend.dev, for production: use verified domain
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=RAIMS Notifications

# ─── File Upload ──────────────────────────────────────────
# Max size in bytes (default 5 MB)
MAX_FILE_SIZE=5242880
# Path is relative to server/ directory
UPLOAD_DIR=./uploads

# ─── MongoDB Memory Server (for testing) ───────────────────
# Auto-handled in test environment (package.json test script)
# No manual config needed — jest-mongodb will spin up in-memory instance
